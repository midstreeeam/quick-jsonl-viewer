{
  "name": "quick-jsonl-viewer",
  "displayName": "Quick JSONL Viewer",
  "description": "View and preview large JSONL files in a readonly, formatted VS Code custom editor.",
  "version": "0.0.4",
  "publisher": "jsh9",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsh9/quick-jsonl-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/jsh9/quick-jsonl-viewer/issues"
  },
  "homepage": "https://github.com/jsh9/quick-jsonl-viewer#readme",
  "keywords": [
    "jsonl",
    "json-lines",
    "json-lines-viewer",
    "large-files",
    "custom-editor"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onCustomEditor:quickJsonlViewer.viewer",
    "onCommand:quickJsonlViewer.openCurrentFile",
    "onCommand:quickJsonlViewer.openSampleFiles"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": false
  },
  "contributes": {
    "commands": [
      {
        "command": "quickJsonlViewer.openCurrentFile",
        "title": "Open in Quick JSONL Viewer",
        "category": "Quick JSONL Viewer"
      }
    ],
    "languages": [
      {
        "id": "jsonl",
        "aliases": [
          "JSON Lines",
          "jsonl"
        ],
        "extensions": [
          ".jsonl"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "quickJsonlViewer.viewer",
        "displayName": "Quick JSONL Viewer",
        "selector": [
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "**/*.jsonl"
          }
        ],
        "priority": "default"
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "*.jsonl": "quickJsonlViewer.viewer"
      }
    },
    "configuration": {
      "title": "Quick JSONL Viewer",
      "properties": {
        "quickJsonlViewer.maxLines": {
          "type": "integer",
          "default": 20,
          "minimum": 0,
          "description": "Number of JSONL lines to load for display. Set to 0 to index the full file and render visible rows on demand."
        },
        "quickJsonlViewer.indent": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "description": "Number of spaces used to indent JSON in Pretty print mode."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "quickJsonlViewer.openCurrentFile"
        }
      ],
      "editor/title": [
        {
          "command": "quickJsonlViewer.openCurrentFile",
          "when": "resourceExtname == .jsonl",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "quickJsonlViewer.openCurrentFile",
          "when": "resourceExtname == .jsonl",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run compile:extension && npm run typecheck:webview && npm run build:webview",
    "compile:extension": "tsc -p ./",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "build:webview": "node scripts/build-webview.cjs",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "prepare": "husky",
    "test": "npm run format:check && npm run compile && npm run test:coverage",
    "test:coverage": "c8 --all --src out/src --include 'out/src/**/*.js' --check-coverage --lines 95 --branches 95 --functions 95 npm run test:unit",
    "test:unit": "node scripts/run-tests.cjs",
    "test:vscode": "npm run compile && vscode-test",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.14.8",
    "@types/vscode": "1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "mocha": "^11.7.6",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3"
  }
}
